# Microsoft Foundry IQ integration (client-side runtime defaults)
# Do NOT store real keys in source control. .env files are gitignored.
#
# Provisioned Foundry AI Services account (Algorithm Arena project):
#   account: ai-account-skldjimkph5a6
#   region:  northcentralus
#   project: ai-project-algorithm-arena
#   deployment: gpt-41-mini (model: gpt-4.1-mini @ 2025-04-14)
#
# Browsers cannot call *.cognitiveservices.azure.com directly (no CORS).
# In dev, the Vite proxy (vite.config.ts) forwards /foundry/* to the account.
# In prod, point this at your own reverse proxy that injects the bearer token.
VITE_FOUNDRY_IQ_ENDPOINT_URL=/foundry
VITE_FOUNDRY_IQ_DEPLOYMENT=gpt-41-mini
VITE_FOUNDRY_IQ_API_VERSION=2025-01-01-preview
# valid values: api-key | bearer (account has disableLocalAuth=true -> use bearer)
VITE_FOUNDRY_IQ_AUTH_MODE=bearer

# Optional: override the dev proxy target without editing vite.config.ts
# VITE_FOUNDRY_PROXY_TARGET=https://<your-account>.cognitiveservices.azure.com
