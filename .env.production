# Production defaults injected at `npm run build` (Vite picks up automatically).
# Safe to commit: these are NOT secrets, just public routing defaults for the
# hosted Static Web App. Real keys live as SWA app settings on the server side.
VITE_FOUNDRY_IQ_ENDPOINT_URL=/api/chat
VITE_FOUNDRY_IQ_DEPLOYMENT=gpt-41-mini
VITE_FOUNDRY_IQ_API_VERSION=2025-01-01-preview
VITE_FOUNDRY_IQ_AUTH_MODE=relay
